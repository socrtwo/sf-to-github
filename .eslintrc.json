{
  "env": {
    "node": true,
    "es2022": true,
    "jest": true,
    "browser": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": "error",
    "no-eval": "error",
    "no-implied-eval": "error"
  }
}
